{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://masterthesis.local/schemas/hs01/session-1.0.0.schema.json",
  "title": "HS-01 Session Record (output)",
  "description": "Output schema: one record per participant session. TIMING MODEL: all *_ms fields are monotonic millisecond offsets from session start (performance.now origin), immune to wall-clock adjustment; wall-clock ISO timestamps exist only at session boundaries plus server receipt. Trial onset = stimulus fully rendered (image decode complete), not navigation. Derived reaction times are computed in analysis as differences and are never stored. Responses are coded semantically (ANCHOR_WORD/TARGET_WORD), with the realized display order logged per trial.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": { "^x_": {} },
  "required": [
    "schema_version", "study_id", "config_version", "config_sha256",
    "session_id", "form_id", "rng_seed", "status",
    "participant", "environment", "timing", "phase_timings", "trials"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "study_id": { "type": "string" },
    "config_version": { "type": "string" },
    "config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "Binds the session to the exact config file." },
    "app_version": { "type": ["string", "null"] },
    "session_id": { "type": "string", "format": "uuid" },
    "form_id": { "type": "string" },
    "rng_seed": { "type": ["string", "integer"], "description": "Session randomization seed; with the config this reproduces trial and option order exactly." },
    "status": {
      "enum": ["completed", "abandoned"],
      "description": "Exclusion (attention rule) is an analysis-stage decision and is NOT stored here; raw outcomes live in quality_summary."
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_code", "consent"],
      "properties": {
        "participant_code": { "type": "string", "pattern": "^P[0-9]{3,}$", "description": "Anonymous code; no personal data anywhere in this record." },
        "recruitment_channel": { "enum": ["tum", "fortiss", "personal", "other", null] },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["given", "consent_version", "at_utc"],
          "properties": {
            "given": { "const": true },
            "consent_version": { "type": "string" },
            "at_utc": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_agent", "viewport", "device_pixel_ratio"],
      "properties": {
        "user_agent": { "type": "string" },
        "platform": { "type": ["string", "null"] },
        "viewport": { "$ref": "#/$defs/dimensions" },
        "screen": { "anyOf": [{ "$ref": "#/$defs/dimensions" }, { "type": "null" }] },
        "device_pixel_ratio": { "type": "number", "exclusiveMinimum": 0 },
        "is_touch": { "type": ["boolean", "null"] },
        "render_check": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["passed"],
              "properties": {
                "passed": { "type": "boolean", "description": "Homoglyph string rendered un-normalized (stimulus fidelity check at session start)." },
                "method": { "type": ["string", "null"] }
              }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at_utc"],
      "properties": {
        "started_at_utc": { "type": "string", "format": "date-time" },
        "completed_at_utc": { "anyOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "server_received_at_utc": { "anyOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "total_duration_ms": { "type": ["integer", "null"], "minimum": 0, "description": "Monotonic; session start to final submit." }
      }
    },
    "phase_timings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase_id", "entered_ms", "exited_ms"],
        "properties": {
          "phase_id": { "enum": ["consent", "instructions", "text", "image", "pair", "demographics"] },
          "entered_ms": { "type": "integer", "minimum": 0 },
          "exited_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "trials": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/trial" } },
    "demographics": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["age_band", "ml_familiarity", "english_proficiency"],
          "properties": {
            "age_band": { "enum": ["18_24", "25_34", "35_44", "45_54", "55_plus", "prefer_not_to_say"] },
            "ml_familiarity": { "enum": ["no_experience", "some_exposure", "regular_practice", "prefer_not_to_say"] },
            "english_proficiency": { "enum": ["A1", "A2", "B1", "B2", "C1", "C2", "native", "prefer_not_to_say"] },
            "comment": { "type": ["string", "null"] }
          }
        },
        { "type": "null" }
      ],
      "description": "Null only for abandoned sessions."
    },
    "integrity_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at_ms", "type"],
        "properties": {
          "at_ms": { "type": "integer", "minimum": 0 },
          "type": { "enum": ["blur", "focus", "visibility_hidden", "visibility_visible", "resize", "fullscreen_exit"] },
          "detail": { "type": ["string", "null"] }
        }
      },
      "description": "Tab switches / focus loss during judgment phases; quality covariate, not an exclusion criterion by itself."
    },
    "quality_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attention_total", "attention_failed"],
      "properties": {
        "attention_total": { "type": "integer", "minimum": 0 },
        "attention_failed": { "type": "integer", "minimum": 0 },
        "focus_loss_count": { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  },
  "$defs": {
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["w", "h"],
      "properties": {
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 }
      }
    },
    "trial": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": { "^x_": {} },
      "required": [
        "trial_index", "phase_id", "position_in_phase",
        "item_id", "source_id", "item_kind", "is_attention_check",
        "presented", "response", "timing"
      ],
      "properties": {
        "trial_index": { "type": "integer", "minimum": 0, "description": "Global 0-based order over the whole session." },
        "phase_id": { "enum": ["text", "image", "pair"] },
        "position_in_phase": { "type": "integer", "minimum": 0 },
        "item_id": { "type": "string", "pattern": "^(txt|img|pair)-[A-Za-z0-9_-]+$" },
        "source_id": { "type": "string", "pattern": "^src-[A-Za-z0-9_-]+$", "description": "Denormalized from the item pool for analysis convenience." },
        "item_kind": { "enum": ["text", "image", "pair"] },
        "is_attention_check": { "type": "boolean" },
        "presented": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale_id": { "type": ["string", "null"], "description": "Text/image trials." },
            "option_display_order": {
              "type": ["array", "null"],
              "items": { "enum": ["ANCHOR_WORD", "TARGET_WORD", "OTHER_CLASS", "NOTHING_RECOGNIZABLE", "CANT_TELL"] },
              "uniqueItems": true,
              "description": "Pair trials: realized on-screen order (AB randomization log)."
            },
            "option_labels": {
              "anyOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["ANCHOR_WORD", "TARGET_WORD"],
                  "properties": {
                    "ANCHOR_WORD": { "type": "string" },
                    "TARGET_WORD": { "type": "string" }
                  }
                },
                { "type": "null" }
              ],
              "description": "Literal word strings shown, denormalized as a safety net against pool/config divergence."
            },
            "rendered_image": {
              "anyOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["css_w", "css_h", "natural_w", "natural_h"],
                  "properties": {
                    "css_w": { "type": "integer", "minimum": 1 },
                    "css_h": { "type": "integer", "minimum": 1 },
                    "natural_w": { "type": "integer", "minimum": 1 },
                    "natural_h": { "type": "integer", "minimum": 1 }
                  }
                },
                { "type": "null" }
              ],
              "description": "Actual on-screen size vs natural size — verifies the no-upscaling fidelity rule per trial."
            }
          }
        },
        "response": {
          "type": "object",
          "additionalProperties": false,
          "required": ["n_changes"],
          "properties": {
            "scale_value": { "type": "integer", "minimum": 1, "maximum": 5, "description": "Text/image trials (5-point Likert)." },
            "choice": {
              "enum": ["ANCHOR_WORD", "TARGET_WORD", "OTHER_CLASS", "NOTHING_RECOGNIZABLE", "CANT_TELL"],
              "description": "Pair trials; semantic coding, independent of display position."
            },
            "other_class_text": { "type": ["string", "null"], "description": "Optional free text when choice = OTHER_CLASS." },
            "n_changes": { "type": "integer", "minimum": 0, "description": "Times the answer was changed before submit." }
          }
        },
        "timing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["onset_ms", "submitted_ms"],
          "properties": {
            "image_loaded_ms": { "type": ["integer", "null"], "minimum": 0, "description": "Asset decode complete (image/pair trials); must precede onset_ms." },
            "onset_ms": { "type": "integer", "minimum": 0, "description": "Stimulus fully rendered — the t0 for all reaction-time analysis." },
            "first_interaction_ms": { "type": ["integer", "null"], "minimum": 0 },
            "response_selected_ms": { "type": ["integer", "null"], "minimum": 0, "description": "Last selection before submit." },
            "submitted_ms": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "item_kind": { "enum": ["text", "image"] } } },
          "then": { "properties": { "response": { "required": ["scale_value"] } } }
        },
        {
          "if": { "properties": { "item_kind": { "const": "pair" } } },
          "then": { "properties": { "response": { "required": ["choice"] }, "presented": { "required": ["option_display_order", "option_labels"] } } }
        }
      ]
    }
  }
}
